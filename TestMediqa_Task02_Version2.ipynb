        "    2: \"clarification\"\n",
        "}\n",
        "\n",
        "# convert back to strings\n",
        "df[\"agreement_pred\"] = df[\"agreement\"].map(agreement_map)\n",
        "df[\"severity_pred\"] = df[\"severity\"].map(severity_map)\n",
        "df[\"edit_type_pred\"] = df[\"edit_type\"].map(edit_map)\n",
