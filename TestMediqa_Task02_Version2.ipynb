        "\n",
        "        a, s, e = model(X)\n",
        "\n",
        "        loss_a = loss_fn(a, y1)\n",
        "        loss_s = loss_fn(s, y2)\n",
        "        loss_e = loss_fn(e, y3)\n",
        "\n",
        "        loss = (\n",
