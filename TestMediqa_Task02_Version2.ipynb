        "            \"edit_id\": edit[\"edit_id\"],\n",
        "            \"agreement\": int(a.argmax(dim=1).item()),\n",
        "            \"severity\": int(s.argmax(dim=1).item()),\n",
        "            \"edit_type\": int(e.argmax(dim=1).item())\n",
        "        })"
