        "import pandas as pd\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.nn.functional as F\n",
        "import pydicom\n",
        "from transformers import AutoTokenizer, AutoModel\n",
        "from skimage.transform import resize"
      ],
      "metadata": {
